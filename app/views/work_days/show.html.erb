<div class="container p-2">
    <div class="container px-4">
        <div class="bg-dark text-white d-flex justify-content-end align-items-center gap-2 p-2 flex-wrap">

            <% if @work_day.draft? %>

            <%= link_to "Configure Locations",
    locations_work_day_path(@work_day),
    class: "btn btn-outline-light" %>

            <%= link_to "Edit Slot Requirements",
    edit_slots_work_day_path(@work_day),
    class: "btn btn-outline-light" %>
            <% end %>




            <% if @work_day.generated? %>
            <%= button_to "Reset Roll",
        reset_roll_work_day_path(@work_day),
        method: :post,
        class: "btn btn-secondary",
        data: { turbo: false, confirm: "Reset this day's roll completely?" } %>
            <% end %>

            <% if @work_day.draft? %>
            <%= button_to "Generate Roles",
        generate_roles_work_day_path(@work_day),
        method: :patch,
        class: "btn btn-success",
        data: { turbo: false, confirm: "Generate roles for this day?" } %>
            <% end %>

            <% if @work_day.generated? %>
            <%= button_to "Publish Work Day",
        publish_work_day_path(@work_day),
        method: :post,
        class: "btn btn-success",
        data: { turbo: false, confirm: "Are you sure you want to publish?" } %>
            <% end %>

            <% if @work_day.published? %>
            <%= button_to "Unpublish Work Day",
        unpublish_work_day_path(@work_day),
        method: :post,
        class: "btn btn-secondary",
        data: { turbo: false, confirm: "Reopen this work day?" } %>
            <% end %>

            <%= link_to "Back to Work Days",
      work_days_path,
      class: "btn btn-light" %>

        </div>
        <div class="container mt-1">
            <div class="row">
                <div class="col text-center">
                    <h1 class="fs-3">Operation Date: </h1>
                    <span class="fs-3"><%= @work_day.date %></span>
                    <br><br>
                    <p>
                        <strong>Guides Requested:</strong>
                        <%= @work_day.guides_requested %>
                    </p>


                    <p>
                        <strong>Status:</strong>
                        <%= @work_day.status %>
                    </p>
                </div>
                <div class="col">
                    <% if @work_day.draft? %>
                    <div class="card">

                        <div class="card-header bg-dark text-white">
                            Trips
                        </div>

                        <div class="card-body">

                            <table class="table table-sm">

                                <thead>
                                    <tr>
                                        <th>Location</th>
                                        <th>Guides</th>
                                        <th>Passengers</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    <tr>
                                        <td>Sara-3&4</td>

                                        <td>
                                            <%= @location_counts["Sara-3&4"] || 0 %>
                                        </td>

                                        <td>
                                            <%= @passenger_counts["Sara-3&4"] || 0%>
                                        </td>
                                    </tr>


                                    <tr>
                                        <td>Balsa</td>

                                        <td>
                                            <%= @location_counts["Balsa"] || 0 %>
                                        </td>

                                        <td>
                                            <%= @passenger_counts["Balsa"] || 0 %>
                                        </td>
                                    </tr>


                                    <tr>
                                        <td>PM</td>

                                        <td>
                                            <%= @location_counts["PM"] || 0 %>
                                        </td>

                                        <td>
                                            <%= @passenger_counts["PM"] || 0 %>
                                        </td>
                                    </tr>


                                    <tr>
                                        <td>Privado</td>

                                        <td>
                                            <%= @location_counts["Privado"] || 0 %>
                                        </td>

                                        <td>
                                            <%= @passenger_counts["Privado"] || 0%>
                                        </td>
                                    </tr>

                                </tbody>


                            </table>

                        </div>

                    </div>
                    <%end%>


                </div>

                <div class="col">
                    <!-- NOT AVAILABLE GUIDES -->
                    <div class="card mt-4">
                        <div class="card-header bg-warning text-white">
                            <strong>No disponibles</strong>
                        </div>

                        <div class="card-body">

                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Guide</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    <% date = @work_day.date %>

                                    <!-- Day Off o Vacation del roll -->
                                    <% @work_day.guide_days
      .includes(:guide)
      .where(status: [:vacation, :day_off])
      .joins(:guide)
      .order("guides.priority ASC")
      .each do |gd| %>

                                    <tr>
                                        <td><%= gd.guide.name %></td>

                                        <td>
                                            <% if gd.vacation? %>
                                            <span class="badge bg-danger">Vacation</span>
                                            <% elsif gd.day_off? %>
                                            <span class="badge bg-warning text-dark">Day Off</span>
                                            <% end %>
                                        </td>
                                    </tr>

                                    <% end %>


                                    <!-- Day Off manual -->
                                    <% ManualDayOff
      .includes(:guide)
      .where(date: date)
      .joins(:guide)
      .order("guides.priority ASC")
      .each do |m| %>

                                    <tr>
                                        <td><%= m.guide.name %></td>

                                        <td>
                                            <span class="badge bg-info text-dark">Manual Off</span>
                                        </td>
                                    </tr>

                                    <% end %>

                                </tbody>
                            </table>

                        </div>
                    </div>
                </div>

                <div class="col">
                    <% if @work_day.draft? %>
                    <div class="card">

                        <div class="card-header bg-success text-white">
                            Top Day-Off Balance
                        </div>

                        <div class="card-body">

                            <table class="table table-sm">

                                <thead>
                                    <tr>
                                        <th>Guide</th>
                                        <th>Balance</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    <% Guide
   .active
   .order(day_off_balance: :desc)
   .limit(5)
   .each do |guide| %>

                                    <tr>

                                        <td><%= guide.name %></td>

                                        <td class="<%= 'text-danger fw-bold' if guide.day_off_balance < 0 %>">

                                            <%= guide.day_off_balance %>

                                        </td>

                                    </tr>

                                    <% end %>

                                </tbody>

                            </table>

                        </div>

                    </div>
                    <%end%>
                </div>
            </div>
        </div>

        <!-- TRANSPORTATION -->

        <div class="container mt-4">

            <h4 class="mt-4">Transportation</h4>

            <div class="row">

                <% ["Privado","Sara-3&4","Balsa","PM"].each do |loc| %>

                <div class="col-md-6 col-lg-3">

                    <%= render "buses",
            work_day: @work_day,
            location: loc %>

                </div>

                <% end %>

            </div>

        </div>
    </div>
    <hr>
    <br>
    <!-- AVAILABILITY -->

    <% if @work_day.draft? %>

    <h2>Set Availability</h2>

    <%= form_with url: update_availability_work_day_path(@work_day), method: :patch do %>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Guide</th>
                <th>Status</th>
                <th>Day Off Balance</th>
            </tr>
        </thead>

        <tbody>

            <% @guide_days.ordered_for_display.each do |gd| %>

            <tr>
                <td><%= gd.guide.name %></td>

                <td>
                    <%= select_tag "availability[#{gd.id}]",
options_for_select(GuideDay.statuses.keys, gd.status) %>
                </td>
                <td class="<%= 'text-danger fw-bold' if gd.guide.day_off_balance < 0 %>">
                    <%= gd.guide.day_off_balance %>
                </td>
            </tr>

            <% end %>

        </tbody>
    </table>

    <%= submit_tag "Save Availability", class:"btn btn-info" %>

    <% end %>

    <% end %>

    <!-- EDIT ROLES -->

    <% if @work_day.generated? %>

    <h2>Edit Roles</h2>

    <%= form_with url: update_roles_work_day_path(@work_day), method: :patch, local: true do %>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Guide</th>
                <th>Current Primary</th>
                <th>New Primary</th>
                <th>Current Secondary</th>
                <th>New Secondary</th>
                <th>Current Location</th>
                <th>New Location</th>
            </tr>
        </thead>

        <tbody>

            <% primary_roles = ["River Guide", "Safety Kayaker", "Photographer"] %>
            <% secondary_roles = ["Head Guide", "Bus Guide", "Driver", "Bus Guide & SendPhotos", "SendPhotos"] %>
            <% locations = ["Balsa","Sara-3&4","PM","Privado"] %>

            <% @guide_days.worked.ordered_for_display.each do |gd| %>

            <tr>

                <td>
                    <strong><%= gd.guide.name %></strong>
                </td>

                <td>
                    <%= gd.role_primary.presence || "-" %>
                </td>

                <td>
                    <%= select_tag "roles[#{gd.id}][role_primary]",
options_for_select(primary_roles, gd.role_primary),
include_blank: true %>
                </td>

                <td>
                    <%= gd.role_secondary.presence || "-" %>
                </td>

                <td>
                    <%= select_tag "roles[#{gd.id}][role_secondary]",
options_for_select(secondary_roles, gd.role_secondary),
include_blank: true %>
                </td>

                <td>
                    <%= gd.location.presence || "-" %>
                </td>

                <td>
                    <%= select_tag "roles[#{gd.id}][location]",
options_for_select(locations, gd.location) %>
                </td>

            </tr>

            <% end %>

        </tbody>
    </table>

    <div class="text-center">
        <%= submit_tag "Save Roles", class:"btn btn-primary" %>
    </div>

    <% end %>
    <hr>
    <!-- form para forzar guia al roll en stand by -->
    <div class="card mt-4">

        <div class="card-header">
            Force Guide Assignment
        </div>

        <div class="card-body">

            <%= form_with url: force_assign_work_day_path(@work_day), method: :post do %>

            <div class="row">

                <div class="col-md-4">

                    <label>Location</label>

                    <%= select_tag :location,
options_for_select(["Balsa","Sara-3&4","Privado","PM"]),
class: "form-control",
id: "force_location" %>

                </div>

                <div class="col-md-4">

                    <label>Required Skills</label>

                    <%= select_tag "skills[]",
options_from_collection_for_select(
Skill.all,
:id,
:name,
Skill.find_by(name: "ClassIII")&.id
),
multiple: true,
class: "form-control",
id: "force_skills" %>

                </div>

                <div class="col-md-3 d-flex align-items-end">

                    <%= submit_tag "Force Assign",
class: "btn btn-warning" %>

                </div>

            </div>

            <% end %>

            <div class="mt-3">

                <strong>Next eligible guide:</strong>

                <span id="preview_guide">
                    Select skills to preview
                </span>

            </div>

        </div>

    </div>
    <script>
        function updateGuidePreview() {

            const skills = Array.from(
                document.getElementById("force_skills").selectedOptions
            ).map(o => o.value)

            fetch("/work_days/<%= @work_day.id %>/preview_force_assign?skills[]=" + skills.join("&skills[]="))
                .then(r => r.json())
                .then(data => {

                    const preview = document.getElementById("preview_guide")

                    if (data.name) {

                        preview.innerHTML =
                            data.name + " (priority " + data.priority + ")"

                    } else {

                        preview.innerHTML =
                            "No standby guide meets requirements"

                    }

                })

        }

        document.getElementById("force_skills")
            .addEventListener("change", updateGuidePreview)

        document.addEventListener("DOMContentLoaded", updateGuidePreview)
    </script>
    <% end %>

    <!-- PUBLISHED VIEW -->

    <% if @work_day.published? %>

    <h3>Assigned Guides</h3>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>Guide</th>
                <th>Status</th>
                <th>Primary Role</th>
                <th>Secondary Role</th>
                <th>Location</th>
            </tr>
        </thead>

        <tbody>

            <% @work_day.guide_days.ordered_for_display.each do |guide_day| %>

            <tr class="<%= guide_day.worked? ? guide_day.location_css_class : '' %>">

                <td><%= guide_day.guide.name %></td>

                <td><%= guide_day.status %></td>

                <td><%= guide_day.role_primary %></td>

                <td><%= guide_day.role_secondary %></td>

                <td>
                    <%= guide_day.worked? ? guide_day.location : "-" %>
                </td>

            </tr>

            <% end %>

        </tbody>
    </table>

    <% end %>

    <hr>

    <!-- DELETE BUTTON -->

    <div class="mt-4">

        <%= button_to "X) Delete Work Day",
delete_with_reset_work_day_path(@work_day),
method: :delete,
class: "btn btn-outline-danger btn-sm",
data: { turbo: false, confirm: "This will permanently delete the Work Day and restore balances. Continue?" } %>

    </div>
</div>