<div class="container-fluid mt-4">
    <h1>Control de libres de oficina</h1>

    <%= render "shared/office_menu" %>

    <div class="mb-3">
        <%= form_with url: office_employee_days_path, method: :get, local: true do %>
        <%= month_field_tag :month, @month.strftime("%Y-%m"),
          class: "form-control d-inline-block",
          style: "width: 220px;" %>

        <%= submit_tag "Ver mes", class: "btn btn-secondary" %>
        <% end %>
    </div>

    <div class="mb-3">
        <%= button_to "Generar libres del mes",
        generate_month_office_employee_days_path(month: @month.strftime("%Y-%m")),
        method: :post,
        class: "btn btn-primary" %>
    </div>

    <% quincenas = [
    ["Primera quincena", @range.select { |date| date.day <= 15 }],
    ["Segunda quincena", @range.select { |date| date.day >= 16 }]
  ] %>

    <% quincenas.each do |title, dates| %>
    <h3 class="mt-4"><%= title %></h3>

    <table class="table table-bordered table-sm align-middle">
        <thead>
            <tr>
                <th style="width: 140px;">Fecha</th>

                <% @employees.each do |employee| %>
                <th class="text-center">
                    <%= employee.name %><br>
                    <small><%= employee.department.presence || "Sin departamento" %></small>
                </th>
                <% end %>
            </tr>
        </thead>

        <tbody>
            <% dates.each do |date| %>
            <% holiday = @holidays[date] %>

            <tr class="<%= 'table-warning' if holiday.present? %>">
                <td>
                    <strong><%= date.day %></strong>
                    <small><%= I18n.l(date, format: "%a") %></small>

                    <% if holiday.present? %>
                    <br>
                    <small><strong>Feriado</strong></small>
                    <% end %>
                </td>

                <% @employees.each do |employee| %>
                <% day = @employee_days[[employee.id, date]] %>

                <td class="text-center">
                    <% if day.present? %>
                    <%= link_to edit_office_employee_day_path(day),
                      class: "text-decoration-none" do %>

                    <% if day.day_off? %>
                    <span class="badge bg-success">Libre</span>
                    <% elsif day.vacation? %>
                    <span class="badge bg-info text-dark">Vacaciones</span>
                    <% elsif day.sick_leave? %>
                    <span class="badge bg-warning text-dark">Incap.</span>
                    <% elsif day.unjustified_absence? %>
                    <span class="badge bg-danger">Ausencia</span>
                    <% elsif day.holiday_worked? %>
                    <span class="badge bg-primary">Feriado</span>
                    <% else %>
                    <span class="badge bg-light text-dark">Editar</span>
                    <% end %>

                    <% if day.holiday_paid? %>
                    <br>
                    <small>Pagado</small>
                    <% end %>
                    <% end %>
                    <% else %>
                    <%= link_to new_office_employee_day_path(
                        office_employee_id: employee.id,
                        date: date
                      ),
                      class: "text-decoration-none" do %>

                    <% if holiday.present? %>
                    <span class="badge bg-warning text-dark">Trabaja / Feriado</span>
                    <% else %>
                    <span class="badge bg-secondary">Trabaja</span>
                    <% end %>
                    <% end %>
                    <% end %>
                </td>
                <% end %>
            </tr>
            <% end %>
        </tbody>
    </table>
    <% end %>
</div>