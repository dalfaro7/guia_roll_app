<div class="container-fluid mt-4">
    <h1>Control de libres de oficina</h1>

    <%= render "shared/office_menu" %>

    <div class="mb-3">
        <%= form_with url: office_employee_days_path, method: :get, local: true do %>
        <%= month_field_tag :month,
          @month.strftime("%Y-%m"),
          class: "form-control d-inline-block",
          style: "width: 220px;" %>

        <%= submit_tag "Ver mes", class: "btn btn-secondary" %>
        <% end %>
    </div>

    <div class="mb-3">
        <%= button_to "Generar libres del mes",
        generate_month_office_employee_days_path(month: @month.strftime("%Y-%m")),
        method: :post,
        class: "btn btn-primary" %>
    </div>

    <table class="table table-bordered align-middle">
        <thead>
            <tr>
                <% ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"].each do |day_name| %>
                <th class="text-center" style="width: 14.28%;">
                    <%= day_name %>
                </th>
                <% end %>
            </tr>
        </thead>

        <tbody>
            <% @weeks.each do |week_range| %>
            <tr>
                <% week_range.each do |date| %>
                <% holiday = @holidays[date] %>
                <% outside_month = !@month_range.cover?(date) %>

                <td class="<%= 'table-warning' if holiday.present? %> <%= 'table-light' if outside_month %>" style="height: 160px; vertical-align: top;">

                    <div class="d-flex justify-content-between">
                        <strong>
                            <%= date.day %>
                        </strong>

                        <% if outside_month %>
                        <small class="text-muted">
                            <%= date.strftime("%b") %>
                        </small>
                        <% end %>
                    </div>

                    <% if holiday.present? %>
                    <div class="mb-1">
                        <span class="badge bg-warning text-dark">
                            Feriado
                        </span>
                    </div>
                    <% end %>

                    <% @employees.each do |employee| %>
                    <% day = @employee_days[[employee.id, date]] %>

                    <% if day.present? %>
                    <div class="mb-1">
                        <%= link_to edit_office_employee_day_path(day),
                        class: "text-decoration-none" do %>

                        <% if day.day_off? %>
                        <span class="badge bg-success">Libre</span>
                        <% elsif day.vacation? %>
                        <span class="badge bg-info text-dark">Vac.</span>
                        <% elsif day.sick_leave? %>
                        <span class="badge bg-warning text-dark">Incap.</span>
                        <% elsif day.unjustified_absence? %>
                        <span class="badge bg-danger">Aus.</span>
                        <% elsif day.holiday_worked? %>
                        <span class="badge bg-primary">Feriado Trab.</span>
                        <% end %>

                        <small>
                            <%= employee.name.split.first %>
                        </small>

                        <% if day.holiday_paid? %>
                        <small>Pagado</small>
                        <% end %>
                        <% end %>
                    </div>
                    <% end %>
                    <% end %>

                    <div class="mt-2">
                        <%= link_to "+ registro",
                    new_office_employee_day_path(date: date),
                    class: "btn btn-sm btn-outline-secondary w-100" %>
                    </div>
                </td>
                <% end %>
            </tr>
            <% end %>
        </tbody>
    </table>
</div>