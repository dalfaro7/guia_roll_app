<div class="container">
    <h1>Audit Log</h1>

    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>User</th>
                <th>Action</th>
                <th>Model</th>
                <th>Work Day</th>
                <th>Guide</th>
                <th>Screen</th>
                <th>Component</th>
                <th>Details</th>
            </tr>
        </thead>

        <tbody>
            <% @audit_logs.each do |log| %>
            <tr>
                <td><%= log.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                <td><%= log.user&.name || log.user&.username || "System" %></td>
                <td><%= log.action %></td>
                <td><%= "#{log.auditable_type} ##{log.auditable_id}" %></td>
                <td><%= log.work_day&.date || "-" %></td>
                <td><%= log.metadata&.dig("guide_name") || "-" %></td>
                <td><%= log.metadata&.dig("screen") || "-" %></td>
                <td><%= log.metadata&.dig("component") || "-" %></td>
                <td>
                    <pre style="white-space: pre-wrap;"><%= JSON.pretty_generate(log.metadata || {}) %></pre>
                </td>
            </tr>
            <% end %>
        </tbody>
    </table>
</div>