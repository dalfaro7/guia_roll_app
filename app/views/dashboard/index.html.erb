<div class="container-fluid py-4">

    <!-- ======================================================
       HEADER / FILTRO PRINCIPAL DE MES
       Este formulario conserva también los filtros actuales
       de rol especial y guía seleccionada.
       ====================================================== -->
    <div class="d-flex justify-content-between align-items-end flex-wrap mb-4">
        <div>
            <h1 class="mb-1">Equity Dashboard</h1>
            <p class="text-muted mb-0">
                <%= @month.strftime("%B %Y") %>
            </p>
        </div>

        <%= form_with url: dashboard_path, method: :get, local: true, class: "d-flex gap-2 align-items-end" do %>
        <%= hidden_field_tag :special_role, @selected_special_role %>
        <%= hidden_field_tag :guide_id, @selected_guide&.id %>

        <div>
            <%= label_tag :month, "Select Month", class: "form-label" %>
            <%= month_field_tag :month, @month.strftime("%Y-%m"), class: "form-control" %>
        </div>

        <%= submit_tag "View", class: "btn btn-primary" %>
        <% end %>
    </div>

    <!-- ======================================================
       KPI CARDS
       Resumen operativo del mes seleccionado.
       ====================================================== -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Días del mes con asignación</small>
                    <h3 class="mb-0"><%= @worked_month_days %></h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Puestos de trabajo asignados</small>
                    <h3 class="mb-0"><%= @assigned_work_slots %></h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <small class="text-muted">Promedio de puestos por guía</small>
                    <h3 class="mb-0"><%= @average.to_f.round(2) %></h3>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================================================
       GRÁFICO PRINCIPAL DE EQUIDAD
       Muestra distribución de asignaciones por guía.
       ====================================================== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            Worked Days Distribution
        </div>

        <div class="card-body">
            <%= column_chart @chart_data,
        height: "400px",
        library: {
          plugins: {
            legend: { display: false }
          }
        } %>
        </div>
    </div>

    <!-- ======================================================
       TABLA PRINCIPAL DE EQUIDAD
       Incluye todos los guías, incluso con 0 asignaciones.
       ====================================================== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-secondary text-white">
            Guide Equity Detail
        </div>

        <div class="card-body table-responsive">
            <table class="table table-bordered table-sm align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Guide</th>
                        <th>Worked Days</th>
                        <th>% Participation</th>
                        <th>Deviation</th>
                    </tr>
                </thead>

                <tbody>
                    <% @dashboard_data.each do |data| %>
                    <tr class="<%= 'table-danger' if data[:deviation].to_f > 1 %> <%= 'table-success' if data[:deviation].to_f < -1 %>">
                        <td><%= data[:guide].name %></td>
                        <td><%= data[:worked] %></td>
                        <td><%= data[:percentage] %>%</td>
                        <td><%= data[:deviation] %></td>
                    </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ======================================================
       ROLES ESPECIALES
       Control de asignaciones de Safety Kayaker,
       Photographer y Bus Guide.
       ====================================================== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-dark">
            Special Role Assignments
        </div>

        <div class="card-body">

            <!-- FILTRO POR FUNCIÓN ESPECIAL
           Este formulario conserva el mes y el guía seleccionado. -->
            <%= form_with url: dashboard_path, method: :get, local: true, class: "row g-3 mb-4" do %>
            <%= hidden_field_tag :month, @month.strftime("%Y-%m") %>
            <%= hidden_field_tag :guide_id, @selected_guide&.id %>

            <div class="col-md-4">
                <%= label_tag :special_role, "Filter by special role", class: "form-label" %>

                <%= select_tag :special_role,
            options_for_select(
              [
                ["All", "all"],
                ["Safety Kayaker", "safety_kayaker"],
                ["Photographer", "photographer"],
                ["Bus Guide", "bus_guide"]
              ],
              @selected_special_role
            ),
            class: "form-control" %>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <%= submit_tag "Apply", class: "btn btn-primary w-100" %>
            </div>
            <% end %>

            <!-- GRÁFICO DE ROLES ESPECIALES
           Usa @special_role_chart_data, que ya viene filtrado
           desde el controller. -->
            <%= column_chart [
            {
              name: "Safety Kayaker",
              data: @special_role_chart_data.map { |d| [d[:name], d[:"Safety Kayaker"].to_i] }
            },
            {
              name: "Photographer",
              data: @special_role_chart_data.map { |d| [d[:name], d[:"Photographer"].to_i] }
            },
            {
              name: "Bus Guide",
              data: @special_role_chart_data.map { |d| [d[:name], d[:"Bus Guide"].to_i] }
            }
          ],
          height: "450px",
          stacked: true,
          library: {
            plugins: {
              legend: { display: true }
            }
          } %>

            <hr>

            <!-- TABLA DE ROLES ESPECIALES
           Usa la misma data filtrada que el gráfico. -->
            <div class="table-responsive">
                <table class="table table-bordered table-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Guide</th>
                            <th>Safety Kayaker</th>
                            <th>Photographer</th>
                            <th>Bus Guide</th>
                            <th>Total</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% if @filtered_special_role_data.any? %>
                        <% @filtered_special_role_data.each do |data| %>
                        <tr>
                            <td><%= data[:guide_name] %></td>
                            <td><%= data[:safety_kayaker] %></td>
                            <td><%= data[:photographer] %></td>
                            <td><%= data[:bus_guide] %></td>
                            <td><strong><%= data[:total] %></strong></td>
                        </tr>
                        <% end %>
                        <% else %>
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                No special role assignments found for this filter.
                            </td>
                        </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    <!-- ======================================================
       HISTÓRICO POR GUÍA
       Este formulario conserva el mes y el filtro de rol especial.
       ====================================================== -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            Historical Guide View
        </div>

        <div class="card-body">
            <%= form_with url: dashboard_path, method: :get, local: true, class: "row g-3 mb-4" do %>
            <%= hidden_field_tag :month, @month.strftime("%Y-%m") %>
            <%= hidden_field_tag :special_role, @selected_special_role %>

            <div class="col-md-5">
                <%= label_tag :guide_id, "Select Guide", class: "form-label" %>

                <%= select_tag :guide_id,
            options_from_collection_for_select(
              @guides,
              :id,
              :name,
              @selected_guide&.id
            ),
            class: "form-control" %>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <%= submit_tag "View Guide", class: "btn btn-primary w-100" %>
            </div>
            <% end %>

            <% if @selected_guide.present? %>
            <h5 class="mb-3">
                Historical Days - <%= @selected_guide.name %>
            </h5>

            <%= line_chart @historical_data,
          xtitle: "Month",
          discrete: true,
          height: "350px" %>
            <% else %>
            <p class="text-muted">
                No guide selected.
            </p>
            <% end %>
        </div>
    </div>

</div>